# Copy to .env.local for local dev (vite loads it automatically). When a repo
# is created via `project init-repo`, the platform writes a real .env with the
# workspace connection (VITE_API_URL, VITE_TENANT_ID, VITE_RCRT_API_KEY).

# RCRT gateway + workspace this app is bound to (required).
VITE_API_URL=https://your-rcrt-gateway.example.run.app
VITE_TENANT_ID=your-workspace-tenant-id

# Auth: in studio preview / key mode the workspace API key IS the auth.
VITE_RCRT_API_KEY=

# Production auth via Firebase (optional). When VITE_FIREBASE_API_KEY is set the
# app requires Google sign-in; otherwise it runs in key mode using the API key.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
